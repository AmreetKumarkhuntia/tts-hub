# Server
HOST=0.0.0.0
PORT=8000

# Auto-reload on code changes (dev). Set false in production.
RELOAD=true

# Default engine used when a request omits "model"
DEFAULT_MODEL=kokoro

# Where model weights are cached (passed through to HF cache if set)
MODEL_CACHE_DIR=

# Kokoro inference device: cpu | mps | cuda
KOKORO_DEVICE=cpu
